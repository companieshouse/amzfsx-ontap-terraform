# Account details

aws_account = "heritage-live-eu-west-2"
aws_region  = "eu-west-2"
environment = "live"

#FSX config
fsx_fs_name             = "CHIPS_ENVP1_FSx"
fsx_storage_capacity    = "5500"
fsx_deployment_type     = "SINGLE_AZ_2"
fsx_throughput_capacity = "1536"
fsx_auto_backup_retention = "0"

#Fsx Create Volumes
create_data_volumes = "true"
create_fra_volumes  = "true"
create_redo_volumes = "true"

#FSX Volume Sizes
chips_envp1_data_size = 5500000
chips_envp1_fra_size  = 650000
chips_envp1_redo_size = 150000

#FSX Volume Counts
chips_envp1_data_count = 6
chips_envp1_fra_count  = 4
chips_envp1_redo_count = 4

# DNS
fsx_fs_mgmt_dns_name = "chips-envp1-fsx-mgmt"

#Cloudwatch
monitoring = "true"
