# Account details
aws_account = "finance-development"
aws_region  = "eu-west-2"
environment = "development"

#FSX config
fsx_fs_name             = "e5_fin_FSx"
fsx_storage_capacity    = 1024
fsx_deployment_type     = "SINGLE_AZ_2"
fsx_throughput_capacity = 384
fsx_auto_backup_retention = 0

#Fsx Create Volumes
create_data_volumes = true
create_fra_volumes  = true
create_redo_volumes = true

#FSX Volume Sizes - e5_fin in Mb
e5_fin_data_size = 600000
e5_fin_fra_size  = 200000
e5_fin_redo_size = 10000

#FSX Volume Counts - e5_fin
e5_fin_data_count = 4
e5_fin_fra_count  = 4
e5_fin_redo_count = 4

# DNS
fsx_fs_mgmt_dns_name = "finance-e5-fin-fsx-mgmt"

#Cloudwatch
monitoring = true